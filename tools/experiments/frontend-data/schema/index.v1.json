{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "index.v1",
  "type": "object",
  "required": ["schema_version", "dataset_id", "runs"],
  "properties": {
    "schema_version": { "const": "index.v1" },
    "dataset_id": { "type": "string" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["run_id"],
        "properties": {
          "run_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
